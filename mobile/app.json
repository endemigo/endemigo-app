{
  "expo": {
    "name": "Endemigo",
    "slug": "endemigo",
    "version": "1.0.0",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "enabled": true,
      "checkAutomatically": "ON_LOAD",
      "fallbackToCacheTimeout": 0,
      "url": "https://u.expo.dev/408b2a07-ac8a-4c67-9a76-f0c76f88ce3d"
    },
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "endemigo",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.endemigo.app",
      "infoPlist": {
        "NSAppTransportSecurity": {
          "NSAllowsArbitraryLoads": false,
          "NSAllowsLocalNetworking": true
        }
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#0097d8",
        "foregroundImage": "./assets/images/android-icon-foreground.png"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.endemigo.app"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "extra": {
      "eas": {
        "build": {
          "experimental": {
            "ios": {
              "appExtensions": [
                {
                  "targetName": "OneSignalNotificationServiceExtension",
                  "bundleIdentifier": "com.endemigo.app.OneSignalNotificationServiceExtension",
                  "entitlements": {
                    "com.apple.security.application-groups": [
                      "group.com.endemigo.app.onesignal"
                    ]
                  }
                }
              ]
            }
          }
        },
        "projectId": "408b2a07-ac8a-4c67-9a76-f0c76f88ce3d"
      },
      "router": {}
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#0097d8",
          "dark": {
            "backgroundColor": "#0097d8"
          }
        }
      ],
      "expo-font",
      "expo-image",
      [
        "expo-image-picker",
        {
          "photosPermission": "Endemigo ürün görselleri yükleyebilmeniz için fotoğraflarınıza erişmek ister.",
          "cameraPermission": false,
          "microphonePermission": false
        }
      ],
      "expo-web-browser",
      "expo-secure-store",
      "expo-localization",
      "expo-status-bar",
      [
        "onesignal-expo-plugin",
        {
          "mode": "development"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "owner": "fthkrtl"
  }
}
