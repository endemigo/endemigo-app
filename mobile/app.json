{
  "expo": {
    "name": "Endemigo",
    "slug": "endemigo",
    "version": "1.0.0",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "enabled": true,
      "checkAutomatically": "ON_LOAD",
      "fallbackToCacheTimeout": 0,
      "url": "https://u.expo.dev/00000000-0000-0000-0000-000000000000"
    },
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "endemigo",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.fthkrtl.endemigo"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#0097d8",
        "foregroundImage": "./assets/images/android-icon-foreground.png"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.fthkrtl.endemigo"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "extra": {
      "eas": {
        "projectId": "00000000-0000-0000-0000-000000000000"
      }
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#0097d8",
          "dark": {
            "backgroundColor": "#0097d8"
          }
        }
      ],
      "expo-font",
      "expo-image",
      [
        "expo-image-picker",
        {
          "photosPermission": "Endemigo ürün görselleri yükleyebilmeniz için fotoğraflarınıza erişmek ister.",
          "cameraPermission": false,
          "microphonePermission": false
        }
      ],
      "expo-web-browser",
      "expo-secure-store",
      "expo-localization",
      "expo-status-bar",
      [
        "onesignal-expo-plugin",
        {
          "mode": "development"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
