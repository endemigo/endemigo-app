{
  "name": "endemigo-admin",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "build": "vite build",
    "preview": "vite preview --host 0.0.0.0",
    "test:e2e": "playwright test",
    "test:unit": "node --test --experimental-strip-types src/__tests__/phase10-admin-smoke.test.ts",
    "test:coverage": "node --test --experimental-strip-types --experimental-test-coverage src/__tests__/phase10-admin-smoke.test.ts && node ../scripts/phase10-coverage-threshold-check.mjs vitest.config.ts branches functions lines statements",
    "phase10:admin-gate": "npm run build && npm run test:coverage && npm run test:e2e"
  },
  "dependencies": {
    "axios": "^1.7.9",
    "jspdf": "^2.5.2",
    "pinia": "^2.3.1",
    "primeicons": "^7.0.0",
    "primevue": "^4.2.5",
    "socket.io-client": "^4.8.3",
    "vue": "^3.5.13",
    "vue-router": "^4.5.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@playwright/test": "^1.49.1",
    "@vitejs/plugin-vue": "^5.2.1",
    "puppeteer": "^25.2.1",
    "typescript": "^5.7.3",
    "vite": "^6.0.7"
  }
}
