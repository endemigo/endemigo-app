# ─── Core ────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3030
APP_URL=http://localhost:3030
CORS_ORIGIN=http://localhost:5173

# ─── Database ────────────────────────────────────────────────────────
DATABASE_URL=postgresql://endemigo:endemigo_dev@localhost:5432/endemigo

# ─── Redis ───────────────────────────────────────────────────────────
# REDIS_URL öncelikli; verilmezse HOST/PORT/PASSWORD kullanılır.
# BullMQ kuyrukları, socket.io adapter ve health check hepsi bu tek
# config'i okur (backend/src/shared/config/redis.config.ts).
# docker-compose Redis'i --requirepass redis_dev ile açılır; compose
# kullanıyorsan REDIS_PASSWORD=redis_dev şart.
# REDIS_URL=redis://:redis_dev@localhost:6379
REDIS_HOST=localhost
REDIS_PORT=6379
# REDIS_PASSWORD=redis_dev

# ─── Auth ────────────────────────────────────────────────────────────
JWT_SECRET=change-me
JWT_EXPIRATION=7d
ADMIN_JWT_EXPIRATION=8h
# ENCRYPTION_KEY=32-byte-hex

# ─── Payments (Iyzico) ───────────────────────────────────────────────
# IYZICO_API_KEY=
# IYZICO_SECRET_KEY=
# IYZICO_BASE_URL=https://sandbox-api.iyzipay.com

# ─── Push (OneSignal) ────────────────────────────────────────────────
# ONESIGNAL_APP_ID=
# ONESIGNAL_REST_API_KEY=

# ─── Storage ─────────────────────────────────────────────────────────
# STORAGE_DRIVER=local | r2
STORAGE_DRIVER=local
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_BUCKET_NAME=
# R2_PUBLIC_URL=

# ─── Dev seed (yalnız development) ───────────────────────────────────
# DEV_SELLER_EMAIL=a@a.com
# DEV_SELLER_PASSWORD=
# DEV_SELLER_FIRST_NAME=
# DEV_SELLER_LAST_NAME=
# DEV_SELLER_BUSINESS_NAME=
# DEV_ADMIN_PASSWORD=
# DEV_ADMIN_DISPLAY_NAME=
