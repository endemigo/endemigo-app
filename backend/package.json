{
  "name": "backend",
  "version": "0.0.1",
  "description": "",
  "author": "",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "build": "nest build",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "dev:stack": "bash ./scripts/start-dev-stack.sh",
    "dev:db:down": "bash ./scripts/stop-dev-stack.sh",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:cov:phase10": "jest --runInBand --watchman=false --coverage --collectCoverageFrom=modules/integration-regression/phase10-regression.matrix.ts --coverageThreshold={\\\"global\\\":{\\\"branches\\\":80,\\\"functions\\\":80,\\\"lines\\\":80,\\\"statements\\\":80}} modules/integration-regression/phase10-regression.matrix.spec.ts",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./test/jest-e2e.json",
    "test:e2e:services": "docker compose -f docker-compose.test.yml up -d --wait",
    "test:e2e:services:down": "docker compose -f docker-compose.test.yml down -v",
    "test:e2e:local": "NODE_ENV=development DATABASE_URL=postgres://endemigo:endemigo_test@localhost:55432/endemigo_test REDIS_HOST=localhost REDIS_PORT=56379 JWT_SECRET=e2e_test_secret npm run test:e2e -- --runInBand --watchman=false",
    "migration:generate": "typeorm-ts-node-commonjs migration:generate -d src/database/datasource.ts",
    "migration:run": "typeorm-ts-node-commonjs migration:run -d src/database/datasource.ts",
    "migration:revert": "typeorm-ts-node-commonjs migration:revert -d src/database/datasource.ts",
    "migration:show": "typeorm-ts-node-commonjs migration:show -d src/database/datasource.ts",
    "phase10:contract": "node ../scripts/phase10-contract-drift.mjs",
    "phase10:inventory": "node ../scripts/phase10-endpoint-inventory.mjs",
    "phase10:contracts": "npm run phase10:contract && npm run phase10:inventory",
    "phase10:backend-gate": "npm run build && npm run test:cov:phase10 && npm run phase10:contracts && npm run test:e2e -- phase10-regression.e2e-spec.ts --runInBand --watchman=false",
    "phase11:functional": "node ../scripts/phase11-evidence.mjs --functional",
    "phase11:security": "node ../scripts/phase11-evidence.mjs --security",
    "phase11:load": "node ../scripts/phase11-evidence.mjs --load",
    "phase11:load:run": "node ../scripts/phase11-run-load.mjs",
    "phase11:reports": "node ../scripts/phase11-evidence.mjs --all",
    "phase11:nyquist": "node --test ../scripts/phase11-evidence.test.mjs ../scripts/phase11-run-load.test.mjs"
  },
  "dependencies": {
    "@nestjs/bullmq": "^11.0.4",
    "@nestjs/common": "^11.0.1",
    "@nestjs/config": "^4.0.3",
    "@nestjs/core": "^11.0.1",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.1.18",
    "@nestjs/platform-socket.io": "^11.1.18",
    "@nestjs/serve-static": "^5.0.4",
    "@nestjs/swagger": "^11.2.6",
    "@nestjs/throttler": "^6.5.0",
    "@nestjs/typeorm": "^11.0.1",
    "@nestjs/websockets": "^11.1.18",
    "@onesignal/node-onesignal": "^5.5.0",
    "@socket.io/redis-adapter": "^8.3.0",
    "bcrypt": "^6.0.0",
    "bullmq": "^5.73.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "helmet": "^8.1.0",
    "ioredis": "^5.10.1",
    "iyzipay": "^2.0.67",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "passport-local": "^1.0.0",
    "pg": "^8.20.0",
    "redis": "^5.11.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "sharp": "^0.34.5",
    "socket.io": "^4.8.3",
    "typeorm": "^0.3.28",
    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.2.0",
    "@eslint/js": "^9.18.0",
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.1",
    "@types/bcrypt": "^6.0.0",
    "@types/express": "^5.0.0",
    "@types/jest": "^30.0.0",
    "@types/multer": "^2.1.0",
    "@types/node": "^24.0.0",
    "@types/passport-jwt": "^4.0.1",
    "@types/passport-local": "^1.0.38",
    "@types/supertest": "^7.0.0",
    "@types/uuid": "^10.0.0",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-prettier": "^5.2.2",
    "globals": "^17.0.0",
    "jest": "^30.0.0",
    "prettier": "^3.4.2",
    "source-map-support": "^0.5.21",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "ts-loader": "^9.5.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.20.0"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node",
    "moduleNameMapper": {
      "^@endemigo/shared(.*)$": "<rootDir>/../../shared-types$1"
    }
  }
}
